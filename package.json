{
  "name": "zplr",
  "version": "0.2.0",
  "packageManager": "pnpm@11.15.0",
  "description": "TypeScript library for parsing and rendering ZPL label files",
  "main": "./dist/index.node.js",
  "module": "./dist/index.node.js",
  "types": "./dist/index.node.d.ts",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/le2ni/zplr"
  },
  "exports": {
    ".": {
      "types": "./dist/index.node.d.ts",
      "import": "./dist/index.node.js"
    },
    "./node": {
      "types": "./dist/index.node.d.ts",
      "import": "./dist/index.node.js"
    },
    "./web": {
      "types": "./dist/index.web.d.ts",
      "import": "./dist/index.web.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "USAGE.md",
    "ZPLdocs.md",
    "docs/COMMAND_SUPPORT.md",
    "THIRD_PARTY_NOTICES.md"
  ],
  "scripts": {
    "dev": "pnpm run dev:web",
    "dev:web": "vite",
    "dev:node": "tsx src/examples.ts --env NODE",
    "debug": "tsx --inspect-brk src/examples.ts --env NODE",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:conformance": "vitest run src/core",
    "docs:support": "node --import tsx scripts/generate-support-docs.ts",
    "docs:support:check": "node --import tsx scripts/generate-support-docs.ts --check",
    "font:noto:generate": "node scripts/generate-font-assets.mjs",
    "package:smoke": "node scripts/smoke-package.mjs",
    "package:lint": "publint --strict",
    "package:check": "pnpm run package:smoke && pnpm run package:lint && pnpm pack --dry-run",
    "audit:prod": "pnpm audit --prod",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "build": "tsdown",
    "build:web": "vue-tsc --noEmit -p tsconfig.web.json && vite build",
    "preview:web": "vite preview",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json",
    "verify": "pnpm test && pnpm run docs:support:check && pnpm run typecheck && pnpm run typecheck:web && pnpm run build && pnpm run package:check && pnpm run build:web"
  },
  "keywords": [
    "zpl",
    "label",
    "barcode",
    "parser",
    "renderer",
    "canvas"
  ],
  "author": "Lennart Kurth",
  "license": "MIT",
  "devDependencies": {
    "@fontsource-variable/noto-sans": "5.2.10",
    "@headlessui/vue": "^1.7.23",
    "@iconify-prerendered/vue-mdi": "^0.28.1737398331",
    "@monaco-editor/loader": "^1.6.1",
    "@tailwindcss/postcss": "^4.1.14",
    "@types/node": "^22.18.10",
    "@types/opentype.js": "^1.3.10",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/tsconfig": "^0.8.1",
    "@zxing/library": "0.23.0",
    "esbuild-plugin-path-alias": "^1.0.7",
    "monaco-editor": "^0.54.0",
    "postcss": "^8.5.6",
    "publint": "^0.3.21",
    "tailwindcss": "^4.1.14",
    "tsdown": "^0.22.12",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.1.10",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4",
    "vue": "^3.5.22",
    "vue-tsc": "^3.3.7",
    "wawoff2": "2.0.1"
  },
  "dependencies": {
    "@types/qrcode": "^1.5.5",
    "bwip-js": "^4.11.2",
    "fflate": "^0.8.3",
    "jsbarcode": "^3.12.1",
    "opentype.js": "^2.0.0",
    "qrcode": "^1.5.4"
  },
  "optionalDependencies": {
    "skia-canvas": "^3.0.8"
  }
}
